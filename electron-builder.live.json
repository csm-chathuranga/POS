{
    "appId": "lk.lumac.pos.live",
    "productName": "Lumac POS Live",
    "copyright": "Copyright © 2025 Lumac Solutions",
    "asar": true,
    "directories": {
        "output": "dist-electron-live",
        "buildResources": "build-resources"
    },
    "files": [
        "electron/**/*",
        "package.json"
    ],
    "extraResources": [
        {
            "from": "public",
            "to": "app/public",
            "filter": [
                "lumac-load.jpeg",
                "kumac.jpeg",
                "favicon.ico"
            ]
        }
    ],
    "win": {
        "target": [
            {
                "target": "nsis",
                "arch": ["x64"]
            }
        ],
        "icon": "build-resources/icon.ico"
    },
    "nsis": {
        "oneClick": false,
        "perMachine": false,
        "allowToChangeInstallationDirectory": true,
        "createDesktopShortcut": true,
        "createStartMenuShortcut": true,
        "shortcutName": "Lumac POS Live",
        "installerIcon": "build-resources/icon.ico",
        "uninstallerIcon": "build-resources/icon.ico",
        "installerHeader": "build-resources/installer-header.bmp",
        "license": "build-resources/license.txt"
    }
}
